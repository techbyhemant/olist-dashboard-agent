# Copy to .env.local.
#
# Auth: the /api/generate route calls the Anthropic Messages API via @anthropic-ai/sdk.
# Set a pay-as-you-go Console API key (https://console.anthropic.com):
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Optional: override the model (defaults to claude-sonnet-4-6).
# DASHBOARD_MODEL=claude-sonnet-4-6
#
# Optional: run the full loop with a deterministic stub — no model call, no spend.
# MOCK_LLM=1
#
# Public-demo rate limits (best-effort, in-memory). The hard spend ceiling should
# be a monthly budget limit on the API key in the Anthropic Console.
# RATE_LIMIT_PER_MIN=5      # max requests per minute per IP
# DAILY_REQUEST_CAP=500     # max total model calls per day
